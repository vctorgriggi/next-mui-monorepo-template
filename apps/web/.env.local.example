# Copy this file to .env.local and fill in real values.
# .env.local is gitignored.
#
# Declare each variable used by the app and validate it with Zod in
# `apps/web/lib/env/{client,server}.ts`. Variables starting with
# `NEXT_PUBLIC_` are inlined into the browser bundle at build time —
# never put secrets behind that prefix.

# Example:
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# DATABASE_URL=postgres://user:password@localhost:5432/db
