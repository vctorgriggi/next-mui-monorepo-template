legacy-peer-deps=true

# pnpm: hoist @types/* into the root node_modules. Prevents isolated
# instances of @types/react in transitive deps (which trigger "duplicate
# React types" errors in MUI-based monorepos). Type packages have no
# runtime, so hoisting them carries no phantom-dependency risk.
#
# `pnpm.overrides` in the root package.json handles React/MUI runtime
# pinning so a single version is used across the workspace — no aggressive
# hoist needed for actual runtime packages.
public-hoist-pattern[]=*types*
public-hoist-pattern[]=*eslint*
